  <entry>
    <title>vhdl1 组合电路基础</title>
    <url>/2020/08/04/vhdl1%20%E7%BB%84%E5%90%88%E7%94%B5%E8%B7%AF%E5%9F%BA%E7%A1%80/</url>
    <content><![CDATA[<ul>
<li><p>4 位二进制奇校验器 </p>
</li>
<li><p>8421 码转格雷码 </p>
</li>
<li><p>数码管译码器</p>
</li>
</ul>
<figure class="highlight vhdl"><table><tr><td class="code"><pre><span class="line"><span class="comment">--4位二进制奇校验器</span></span><br><span class="line"><span class="keyword">LIBRARY</span> IEEE;</span><br><span class="line"><span class="keyword">USE</span> IEEE.STD_LOGIC_1164.<span class="keyword">ALL</span>;</span><br><span class="line"></span><br><span class="line"><span class="keyword">ENTITY</span> check <span class="keyword">IS</span></span><br><span class="line">    <span class="keyword">PORT</span>(checkin:<span class="keyword">IN</span> <span class="built_in">STD_LOGIC_VECTOR</span>(<span class="number">3</span> <span class="keyword">downto</span> <span class="number">0</span>);</span><br><span class="line">        checkout:<span class="keyword">OUT</span> <span class="built_in">STD_LOGIC</span>);</span><br><span class="line"><span class="keyword">END</span>;</span><br><span class="line">       </span><br><span class="line"><span class="keyword">ARCHITECTURE</span> check <span class="keyword">of</span> check <span class="keyword">IS</span></span><br><span class="line"><span class="keyword">begin</span></span><br><span class="line">	<span class="keyword">process</span>(checkin)</span><br><span class="line">	<span class="keyword">variable</span> temp:<span class="built_in">std_logic</span>;</span><br><span class="line">	<span class="keyword">begin</span></span><br><span class="line">	temp:=<span class="string">'1'</span>;</span><br><span class="line">	<span class="keyword">for</span> n <span class="keyword">in</span> <span class="number">0</span> <span class="keyword">to</span> <span class="number">3</span> <span class="keyword">loop</span></span><br><span class="line">		temp:=temp <span class="keyword">xor</span> checkin(n); <span class="comment">--奇数为1，偶数为0</span></span><br><span class="line">	<span class="keyword">end</span> <span class="keyword">loop</span>;</span><br><span class="line">	checkout&lt;=temp;</span><br><span class="line">	<span class="keyword">end</span> <span class="keyword">process</span>;</span><br><span class="line"><span class="keyword">end</span>;</span><br></pre></td></tr></table></figure>

<figure class="highlight vhdl"><table><tr><td class="code"><pre><span class="line"><span class="comment">--8421码转格雷码</span></span><br><span class="line"><span class="keyword">LIBRARY</span> IEEE;</span><br><span class="line"><span class="keyword">USE</span> IEEE.STD_LOGIC_1164.<span class="keyword">ALL</span>;</span><br><span class="line"></span><br><span class="line"><span class="keyword">ENTITY</span> convert <span class="keyword">IS</span></span><br><span class="line"><span class="keyword">PORT</span>( cin: <span class="keyword">IN</span> <span class="built_in">STD_LOGIC_vector</span>(<span class="number">3</span> <span class="keyword">downto</span> <span class="number">0</span>);</span><br><span class="line">		cout:<span class="keyword">OUT</span> <span class="built_in">STD_LOGIC_VECTOR</span>(<span class="number">3</span> <span class="keyword">downto</span> <span class="number">0</span>));</span><br><span class="line"><span class="keyword">END</span>;</span><br><span class="line"></span><br><span class="line"><span class="keyword">ARCHITECTURE</span> convert <span class="keyword">of</span> convert <span class="keyword">is</span></span><br><span class="line"><span class="keyword">begin</span></span><br><span class="line">cout(<span class="number">3</span>)&lt;=cin(<span class="number">3</span>);</span><br><span class="line">cout(<span class="number">2</span>)&lt;=cin(<span class="number">2</span>) <span class="keyword">xor</span> cin(<span class="number">3</span>);</span><br><span class="line">cout(<span class="number">1</span>)&lt;=cin(<span class="number">1</span>) <span class="keyword">xor</span> cin(<span class="number">2</span>);</span><br><span class="line">cout(<span class="number">0</span>)&lt;=cin(<span class="number">0</span>) <span class="keyword">xor</span> cin(<span class="number">1</span>);</span><br><span class="line"><span class="keyword">end</span>;</span><br></pre></td></tr></table></figure>

<figure class="highlight vhdl"><table><tr><td class="code"><pre><span class="line"><span class="comment">--数码管译码器</span></span><br><span class="line"><span class="keyword">LIBRARY</span> IEEE;</span><br><span class="line"><span class="keyword">USE</span> IEEE.STD_LOGIC_1164.<span class="keyword">ALL</span>;</span><br><span class="line"><span class="keyword">USE</span> IEEE.STD_LOGIC_UNSIGNED.<span class="keyword">ALL</span>;</span><br><span class="line"></span><br><span class="line"><span class="keyword">ENTITY</span> led <span class="keyword">IS</span></span><br><span class="line">    <span class="keyword">port</span>(</span><br><span class="line">    adr:<span class="keyword">IN</span> <span class="built_in">std_logic_vector</span>(<span class="number">3</span> <span class="keyword">downto</span> <span class="number">0</span>);</span><br><span class="line">    ledshow:<span class="keyword">OUT</span> <span class="built_in">std_logic_vector</span>(<span class="number">6</span> <span class="keyword">downto</span> <span class="number">0</span>));</span><br><span class="line"><span class="keyword">END</span>;</span><br><span class="line">    </span><br><span class="line"><span class="keyword">ARCHITECTURE</span> led <span class="keyword">of</span> led <span class="keyword">IS</span></span><br><span class="line"><span class="keyword">begin</span></span><br><span class="line">    ledshow&lt;=<span class="string">"1111110"</span> <span class="keyword">when</span> adr=<span class="string">"0000"</span> <span class="keyword">else</span> <span class="comment">--0</span></span><br><span class="line">       <span class="string">"0001100"</span> <span class="keyword">when</span> adr=<span class="string">"0001"</span> <span class="keyword">else</span> <span class="comment">--1</span></span><br><span class="line">       <span class="string">"1101101"</span> <span class="keyword">when</span> adr=<span class="string">"0010"</span> <span class="keyword">else</span> <span class="comment">--2</span></span><br><span class="line">       <span class="string">"1111001"</span> <span class="keyword">when</span> adr=<span class="string">"0011"</span> <span class="keyword">else</span> <span class="comment">--3        </span></span><br><span class="line">       <span class="string">"0110011"</span> <span class="keyword">when</span> adr=<span class="string">"0100"</span> <span class="keyword">else</span> <span class="comment">--4</span></span><br><span class="line">       <span class="string">"1011011"</span> <span class="keyword">when</span> adr=<span class="string">"0101"</span> <span class="keyword">else</span> <span class="comment">--5</span></span><br><span class="line">       <span class="string">"0011111"</span> <span class="keyword">when</span> adr=<span class="string">"0110"</span> <span class="keyword">else</span> <span class="comment">--6</span></span><br><span class="line">       <span class="string">"1110000"</span> <span class="keyword">when</span> adr=<span class="string">"0111"</span> <span class="keyword">else</span> <span class="comment">--7</span></span><br><span class="line">       <span class="string">"1111111"</span> <span class="keyword">when</span> adr=<span class="string">"1000"</span> <span class="keyword">else</span> <span class="comment">--8</span></span><br><span class="line">       <span class="string">"1110011"</span> <span class="keyword">when</span> adr=<span class="string">"1000"</span> <span class="keyword">else</span> <span class="comment">--9</span></span><br><span class="line">       <span class="string">"0000000"</span> ;            </span><br><span class="line"><span class="keyword">end</span>;</span><br></pre></td></tr></table></figure>

]]></content>
